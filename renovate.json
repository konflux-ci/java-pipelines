{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base"
  ],
  "dependencyDashboard": false,
  "tekton": {
    "fileMatch": [
      "\\.yaml$",
      "\\.yml$"
    ],
    "includePaths": [
      ".tekton/**",
      "task/**",
      "external-task/**"
    ]
  },
  "packageRules": [
    {
      "groupName": "tekton-ci",
      "matchFileNames": [
        ".tekton/**"
      ]
    },
    {
      "matchPackageNames": [
        "quay.io/konflux-ci/appstudio-utils"
      ],
      "schedule": [
        "on sunday"
      ]
    }
  ]
}
